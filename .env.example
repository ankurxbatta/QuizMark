# ═══════════════════════════════════════════════════════════════════════════
#  QuizMark – Environment Configuration Template
#
#  1. Copy this file:  cp .env.example .env   (Mac/Linux)
#                      copy .env.example .env  (Windows)
#  2. Fill in REQUIRED values below.
#  3. Never commit .env to git — it contains secrets.
#
#  AI provider split:
#    Gemini    → embeddings (768-dim, free quota)
#    OpenAI    → vision, math, generation, marking  (PRIMARY — paid)
#    Anthropic → vision, math, generation, marking  (FALLBACK — paid)
#
#  The system auto-rotates to the fallback when a provider hits its quota.
#  Both OpenAI and Anthropic are required for reliable operation.
# ═══════════════════════════════════════════════════════════════════════════


# ── Environment ───────────────────────────────────────────────────────────────
# "development" or "production".
# In production: API docs (/docs, /redoc) are disabled and demo-data seeding refuses to run.
ENVIRONMENT=development


# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# setup.sh / setup.bat auto-generate this on first run.
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET

JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=30

# Account lockout (optional — sensible defaults built in). After this many failed
# logins the account locks for LOCKOUT_DURATION_MINUTES.
#MAX_FAILED_LOGIN_ATTEMPTS=10
#LOCKOUT_DURATION_MINUTES=5


# ── Admin account ─────────────────────────────────────────────────────────────
# REQUIRED — instructor login credentials
ADMIN_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
ADMIN_ROLE=instructor


# ── Gemini — embeddings only ──────────────────────────────────────────────────
# Used exclusively for 768-dim vector embeddings (MongoDB index is built on this).
# Free quota. Falls back to OpenAI text-embedding-3-small (same 768-dim) if exhausted.
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY
GEMINI_EMBEDDING_MODEL=gemini-embedding-001


# ── OpenAI — primary paid provider ───────────────────────────────────────────
# Used for: chart/image vision, math formula extraction, question generation, marking.
# Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=REPLACE_WITH_YOUR_OPENAI_API_KEY
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_GENERATION_MODEL=gpt-4o-mini
OPENAI_MARKING_MODEL=gpt-4o-mini


# ── Anthropic — fallback for all LLM tasks ────────────────────────────────────
# Auto-activates when OpenAI hits rate limits or quota.
# Get a key at: https://console.anthropic.com
ANTHROPIC_API_KEY=REPLACE_WITH_YOUR_ANTHROPIC_API_KEY
ANTHROPIC_VISION_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_GENERATION_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MARKING_MODEL=claude-haiku-4-5-20251001


# ── LLM routing ───────────────────────────────────────────────────────────────
GENERATION_LLM_ENABLED=true
GENERATION_LLM_PROVIDER=openai
GENERATION_LLM_MODEL=gpt-4o-mini
GENERATION_MAX_TOKENS=4096

ONLINE_LLM_ENABLED=true
ONLINE_LLM_PROVIDER=openai
ONLINE_LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024


# ── Question generation tuning (optional — sensible defaults built in) ────────
# Bloom's/concept coverage rounds only help LARGE banks; for requests smaller than
# this they are skipped (faster, cheaper) — Round 1 + top-up loops still hit the
# count and the quality gate still runs. Set 0 to always run full coverage.
#GEN_FULL_COVERAGE_MIN_COUNT=6
# How many extra rounds to regenerate when the gate drops a chapter below count.
#GEN_TOPUP_MAX_ROUNDS=3
# For difficulty=hard: verify each question is genuinely multi-step and drop the
# ones that aren't (one cheap LLM call per hard question; runs ONLY for hard).
#GEN_HARD_VERIFY_ENABLED=true
#GEN_HARD_VERIFY_CONCURRENCY=3
# Drop generated questions that are near-duplicates (cosine >= DEDUP_SIMILARITY_THRESHOLD)
# of ones ALREADY stored for the same book, so separate generation runs don't
# accumulate equivalent questions. Off → only within-run dedup applies.
#GEN_BANK_DEDUP_ENABLED=true
# DeepSearch refiner: before the quality gate, each question gets an evidence-
# backed repair pass (multi-index RAG + optional web search + one LLM call) that
# completes missing data and corrects errors so the gate keeps more questions.
#DEEPSEARCH_REFINE_ENABLED=true
#DEEPSEARCH_CONCURRENCY=3
#DEEPSEARCH_RETRIEVAL_K=4
# Web knowledge for the refiner. Uses OpenAI's built-in web_search tool with
# your existing OPENAI_API_KEY (no extra signup); a Tavily key (tavily.com) is
# an optional alternative/fallback. Set DEEPSEARCH_WEB_ENABLED=false for
# book-only refinement.
#DEEPSEARCH_WEB_ENABLED=true
#DEEPSEARCH_WEB_MAX_RESULTS=3
#TAVILY_API_KEY=
# Post-generation quality gate: structural checks + LLM answerability/correctness
# judge. The master switch covers both; the judge can also be disabled alone.
#QUALITY_GATE_ENABLED=true
#QUALITY_JUDGE_ENABLED=true
#QUALITY_JUDGE_CONCURRENCY=3
#QUALITY_JUDGE_RETRIEVAL_K=4


# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000


# ── Celery / Redis ────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://broker:6379/0
CELERY_RESULT_BACKEND=redis://broker:6379/0


# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_ENABLED=true
MONGODB_URL=mongodb://mongodb:27017/?directConnection=true
MONGODB_DB_NAME=marking_tools


# ── Confidence thresholds (marking pipeline) ──────────────────────────────────
# HIGH >= 0.85  →  SLM score accepted, no LLM call
# MID  >= 0.55  →  RAG context + OpenAI marking
# LOW  <  0.55  →  wide RAG + OpenAI + flagged for instructor review
CONFIDENCE_HIGH=0.85
CONFIDENCE_MID=0.55


# ── PDF ingestion limits ──────────────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=25
PDF_MAX_PAGES=700
PDF_MIN_CHUNK_CHARS=300
PDF_MAX_CHUNK_CHARS=3000


# ── RAG retrieval ─────────────────────────────────────────────────────────────
TOP_K_RETRIEVAL=5
TOP_K_WIDE_RETRIEVAL=10
SIMILARITY_THRESHOLD=0.75


# ── Ingestion chain tuning (optional — sensible defaults built in) ────────────
# The LangChain-based ingestion chain (clean → chunk → validate → vision → embed).
# Uncomment only if you need to tune throughput or quality.
#CHUNK_OVERLAP=200                # recursive splitter overlap (chars)
#SEMANTIC_CHUNK_RATIO=0.2         # share of chunks re-split semantically
#SEMANTIC_MIN_CHARS=1500          # only chunks this long are semantic candidates
#INGEST_VISION_CONCURRENCY=4      # parallel vision API calls per window (lower = fewer 429 bursts on large books)
#ENABLE_CHUNK_VALIDATION=true     # LLM math repair before DB insert
#VALIDATION_CONCURRENCY=4         # parallel validation LLM calls
#EMBEDDING_BATCH_SIZE=50          # texts per embedding API call
#GEMINI_EMBEDDING_DELAY_SECONDS=0.7  # pause between embedding batches (throttles Gemini free-tier 429s)
#ENABLE_VISION_EXTRACTION=true    # chart/image vision descriptions
#INGEST_PAGE_WINDOW=6             # pages per checkpoint window
#INGEST_TIME_BUDGET_SECONDS=1500  # task re-queues itself after this long


# ── Specialist RAG indexes (optional — see docs/MULTI_RAG_DESIGN.md) ──────────
#MATH_INDEX_ENABLED=true          # per-formula index built by worker-math
#FIGURE_INDEX_ENABLED=true        # per-figure index built by worker-vision
#TABLE_INDEX_ENABLED=true         # per-table index built by worker-clean
#INDEX_BUILD_BATCH_SIZE=10        # items per enrichment LLM call
#RRF_K=60                         # reciprocal-rank fusion constant
#EXPANSION_NEIGHBORS=2            # parent chunks pulled in via cross-links
