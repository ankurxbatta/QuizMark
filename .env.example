# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=quizapp
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=quizdb
DATABASE_URL=postgresql+asyncpg://quizapp:change_me_in_production@db:5432/quizdb

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
SECRET_KEY=replace_with_a_long_random_secret_key_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=30
MAX_FAILED_LOGIN_ATTEMPTS=3
LOCKOUT_DURATION_MINUTES=5

# ─── Celery / Redis ───────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://broker:6379/0
CELERY_RESULT_BACKEND=redis://broker:6379/1

# ─── Offline LLM (Tier-3) ────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://llm:11434
LLM_MODEL_NAME=llama3
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# ─── SLM (Tier-1 pre-scorer + Stage-A skeleton extractor) ───────────────────
SLM_MODEL_NAME=phi3:mini
SLM_TEMPERATURE=0.0
SLM_MAX_TOKENS=256

# ─── Online LLM (optional Tier-3 fallback) ───────────────────────────────────
ONLINE_LLM_ENABLED=false
ONLINE_LLM_PROVIDER=anthropic
ONLINE_LLM_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ─── RAG / Embeddings ─────────────────────────────────────────────────────────
EMBEDDING_MODEL=nomic-embed-text
TOP_K_RETRIEVAL=5
TOP_K_WIDE_RETRIEVAL=10

# ─── Confidence Router ───────────────────────────────────────────────────────
CONFIDENCE_HIGH=0.85
CONFIDENCE_MID=0.55
SIMILARITY_THRESHOLD=0.75

# ─── PDF Ingestion ────────────────────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=25
# Process up to 620 pages (full textbook). Increase for larger books.
PDF_MAX_PAGES=620
# Minimum characters to keep a text chunk (filters out headers / footers)
PDF_MIN_CHUNK_CHARS=300
# Maximum characters per chunk fed to the LLM at once
PDF_MAX_CHUNK_CHARS=3000

# ─── Application ──────────────────────────────────────────────────────────────
BATCH_SIZE_LIMIT=50
BACKUP_RETENTION_DAYS=30
