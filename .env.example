# Database
POSTGRES_USER=quizuser
POSTGRES_PASSWORD=changeme123
POSTGRES_DB=quizdb
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://quizuser:changeme123@db:5432/quizdb
DATABASE_URL_SYNC=postgresql://quizuser:changeme123@db:5432/quizdb

# Security
SECRET_KEY=your-secret-key-change-this   # REQUIRED: generate with: python -c "import secrets; print(secrets.token_hex(32))"

# Admin account — REQUIRED when ADMIN_ENABLED=true (no default password!)
ADMIN_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now   # REQUIRED: set a strong password here
ADMIN_ROLE=instructor

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Celery
CELERY_BROKER_URL=redis://broker:6379/0
CELERY_RESULT_BACKEND=redis://broker:6379/0

# Ollama Models
SLM_MODEL_NAME=qwen2:0.5b
LLM_MODEL_NAME=qwen2:1.5b
EMBEDDING_MODEL=nomic-embed-text

# Confidence Thresholds
CONFIDENCE_HIGH=0.85
CONFIDENCE_MID=0.55

# Online LLM (optional fallback for LOW confidence)
ONLINE_LLM_ENABLED=false
ONLINE_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=

# OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-4o-mini


# Question Generation
GENERATION_LLM_ENABLED=true
GENERATION_LLM_PROVIDER=gemini
GENERATION_LLM_MODEL=gemini-2.5-flash
GENERATION_MAX_TOKENS=4096
GEMINI_API_KEY=

# Upload limits
UPLOAD_MAX_SIZE_MB=25

# RAG settings
TOP_K_RETRIEVAL=5
TOP_K_WIDE_RETRIEVAL=10

# Redis
REDIS_URL=redis://broker:6379/0
# MongoDB Atlas Local (vector store for PDF source chunks)
MONGODB_ENABLED=true
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB_NAME=marking_tools
