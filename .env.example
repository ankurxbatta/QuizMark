# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=quizapp
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=quizdb
DATABASE_URL=postgresql+asyncpg://quizapp:change_me_in_production@db:5432/quizdb

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
SECRET_KEY=replace_with_a_long_random_secret_key_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=30
MAX_FAILED_LOGIN_ATTEMPTS=3
LOCKOUT_DURATION_MINUTES=5

# ─── Celery / Redis ───────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://broker:6379/0
CELERY_RESULT_BACKEND=redis://broker:6379/1

# ─── Offline LLM (Tier-3 full marker) ────────────────────────────────────────
OLLAMA_BASE_URL=http://llm:11434
LLM_MODEL_NAME=llama3
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# ─── SLM (Tier-1 pre-scorer) — phi3:mini (~2.3 GB, fast on CPU) ──────────────
SLM_MODEL_NAME=phi3:mini
SLM_TEMPERATURE=0.0
SLM_MAX_TOKENS=256

# ─── Online LLM (optional Tier-3 fallback for LOW-confidence answers) ────────
ONLINE_LLM_ENABLED=false          # Set to true to activate
ONLINE_LLM_PROVIDER=anthropic     # "anthropic" | "openai"
ONLINE_LLM_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ─── RAG / Embeddings ─────────────────────────────────────────────────────────
EMBEDDING_MODEL=nomic-embed-text
TOP_K_RETRIEVAL=5
TOP_K_WIDE_RETRIEVAL=10

# ─── Confidence Router thresholds ────────────────────────────────────────────
# HIGH  >= 0.85  → accept SLM mark, skip LLM entirely (~40% of answers)
# MID   >= 0.55  → RAG + offline LLM                  (~45% of answers)
# LOW   <  0.55  → RAG wide + online LLM + flag        (~15% of answers)
CONFIDENCE_HIGH=0.85
CONFIDENCE_MID=0.55
SIMILARITY_THRESHOLD=0.75

# ─── Application ──────────────────────────────────────────────────────────────
BATCH_SIZE_LIMIT=50
BACKUP_RETENTION_DAYS=30
UPLOAD_MAX_SIZE_MB=25
