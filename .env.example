# ═══════════════════════════════════════════════════════════════════════════
#  QuizMark – Environment Configuration Template
#
#  1. Copy this file:   cp .env.example .env      (Linux / macOS)
#                       copy .env.example .env    (Windows)
#  2. Fill in the REQUIRED values below.
#  3. Never commit .env to git – it contains secrets.
#
#  AI provider split (all free tiers):
#    Gemini  → embeddings + chart/image vision  (irreplaceable: 768-dim MongoDB index)
#    Groq    → question generation              (fast, free, llama-3.3-70b)
#    Mistral → answer marking                   (precise instruction-following for rubrics)
#    Groq    → math formula extraction          (vision, llama-3.2-11b)
# ═══════════════════════════════════════════════════════════════════════════


# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED — generate with:  python3 -c "import secrets; print(secrets.token_hex(32))"
# setup.sh / setup.bat will auto-generate this for you on first run.
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET

JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=30


# ── Admin account ─────────────────────────────────────────────────────────────
# REQUIRED — the instructor login for the app
ADMIN_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
ADMIN_ROLE=instructor


# ── Gemini — embeddings + chart vision (REQUIRED) ────────────────────────────
# Used for: PDF chunk embeddings (768-dim) and statistical chart descriptions.
# Kept on Gemini because the MongoDB vector index is built on its 768-dim output.
# Get a FREE key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY

# Embedding model — must stay 768-dim to match the MongoDB vector index
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DELAY_SECONDS=0.8
GEMINI_VISION_DELAY_SECONDS=1.0


# ── Groq — question generation + math vision (REQUIRED) ──────────────────────
# Used for: generating exam questions and extracting LaTeX math formulas from pages.
# Get a FREE key at: https://console.groq.com
GROQ_API_KEY=REPLACE_WITH_YOUR_GROQ_API_KEY
GROQ_GENERATION_MODEL=llama-3.3-70b-versatile
GROQ_MATH_MODEL=llama-3.2-11b-vision-preview


# ── Mistral — answer marking (REQUIRED) ──────────────────────────────────────
# Used for: scoring student answers against marking rubrics.
# Mistral's precise instruction-following makes it well-suited for structured rubric marking.
# Get a FREE key at: https://console.mistral.ai
MISTRAL_API_KEY=REPLACE_WITH_YOUR_MISTRAL_API_KEY
MISTRAL_MARKING_MODEL=mistral-small-latest


# ── Question Generation settings ──────────────────────────────────────────────
GENERATION_LLM_ENABLED=true
GENERATION_LLM_PROVIDER=groq
GENERATION_LLM_MODEL=llama-3.3-70b-versatile
GENERATION_MAX_TOKENS=4096


# ── Marking LLM settings ──────────────────────────────────────────────────────
ONLINE_LLM_ENABLED=true
ONLINE_LLM_PROVIDER=mistral
ONLINE_LLM_MODEL=mistral-small-latest
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024


# ── Optional AI keys (leave blank if not using) ───────────────────────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=


# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000


# ── Celery / Redis ────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://broker:6379/0
CELERY_RESULT_BACKEND=redis://broker:6379/0


# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_ENABLED=true
MONGODB_URL=mongodb://mongodb:27017/?directConnection=true
MONGODB_DB_NAME=marking_tools


# ── Confidence thresholds ─────────────────────────────────────────────────────
# HIGH >= 0.85  →  semantic match accepted, no LLM call needed
# MID  >= 0.55  →  RAG context + Mistral marking
# LOW  <  0.55  →  wide RAG + Mistral + flagged for instructor review
CONFIDENCE_HIGH=0.85
CONFIDENCE_MID=0.55


# ── PDF ingestion limits ──────────────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=25
PDF_MAX_PAGES=700
PDF_MIN_CHUNK_CHARS=300
PDF_MAX_CHUNK_CHARS=3000


# ── RAG retrieval ─────────────────────────────────────────────────────────────
TOP_K_RETRIEVAL=5
TOP_K_WIDE_RETRIEVAL=10
SIMILARITY_THRESHOLD=0.75
