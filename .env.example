# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=quizapp
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=quizdb
DATABASE_URL=postgresql+asyncpg://quizapp:change_me_in_production@db:5432/quizdb

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
SECRET_KEY=replace_with_a_long_random_secret_key_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=30
SESSION_TIMEOUT_MINUTES=30
MAX_FAILED_LOGIN_ATTEMPTS=3
LOCKOUT_DURATION_MINUTES=5

# ─── Celery / Redis ───────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://broker:6379/0
CELERY_RESULT_BACKEND=redis://broker:6379/1

# ─── LLM (Ollama) ─────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://llm:11434
LLM_MODEL_NAME=llama3
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# ─── RAG / Embeddings ─────────────────────────────────────────────────────────
EMBEDDING_MODEL=nomic-embed-text
SIMILARITY_THRESHOLD=0.75
TOP_K_RETRIEVAL=5

# ─── Application ──────────────────────────────────────────────────────────────
BATCH_SIZE_LIMIT=50
BACKUP_RETENTION_DAYS=30
UPLOAD_MAX_SIZE_MB=10

# ─── AWS Secrets Manager naming convention (Phase 2) ──────────────────────────
# /quizapp/prod/SECRET_KEY
# /quizapp/prod/DATABASE_URL
# /quizapp/prod/POSTGRES_PASSWORD
